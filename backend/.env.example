# Server Configuration
PORT=5000
NODE_ENV=development

# Database Configuration
DB_HOST=localhost
DB_PORT=5432
DB_USER=rentmanager
DB_PASSWORD=your_password_here
DB_NAME=rentmanager_db

# Home Assistant Integration
HA_SERVER_URL=http://192.168.1.x:8123
HA_API_TOKEN=your_token_here

# Waveshare Relay Mapping (JSON format - update with actual entity IDs)
RELAY_CONFIG='{"1":"switch.shop_1_power","2":"switch.room_1_power"}'

# WhatsApp Configuration
WHATSAPP_READY_TIMEOUT=30000

# JWT Secret — generate a strong random string: openssl rand -hex 32
JWT_SECRET=your_jwt_secret_here

# Login Credentials — add ONLY on the server, never commit real values
LOGIN_USERNAME=your_username
LOGIN_PASSWORD=your_strong_password

# Session duration in hours
SESSION_HOURS=24

# Scheduler Timings (IST)
REMINDER_TIME=09:00
POWER_CUTOFF_TIME=23:00
SYNC_INTERVAL=6h

# Timezone
TZ=Asia/Kolkata
