# RentManager Environment Configuration Template
# Copy this file to .env and fill in your actual values

# ============ SERVER CONFIGURATION ============
PORT=5000
NODE_ENV=development  # Set to 'production' for deployment

# ============ DATABASE ============
# Using SQLite by default (file-based, no external DB needed)
# Database file: ./database/rentmanager.db
# For PostgreSQL migration, uncomment these:
# DB_HOST=localhost
# DB_PORT=5432
# DB_NAME=rentmanager
# DB_USER=postgres
# DB_PASSWORD=your_password

# ============ TIMEZONE ============
# IMPORTANT: This affects all scheduling and time calculations
# Must be an IANA timezone identifier
TZ=Asia/Kolkata

# ============ AUTHENTICATION ============
# Set REQUIRE_AUTH=true to enforce authentication on all endpoints
# This is CRITICAL for production deployments
REQUIRE_AUTH=false  # Set to 'true' in production
ADMIN_TOKEN=default-admin-token-change-immediately
JWT_SECRET=your-jwt-secret-key-change-in-production

# ============ HOME ASSISTANT INTEGRATION ============
# Configure these to connect with your Home Assistant instance
HA_SERVER_URL=http://192.168.1.100:8123  # Your Home Assistant URL
HA_API_TOKEN=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...  # Your HA Long-lived Access Token

# ============ WHATSAPP CONFIGURATION ============
# For WhatsApp notifications (currently uses Playwright automation)
# WARNING: Current implementation is fragile; recommend migrating to Twilio API
WHATSAPP_READY_TIMEOUT=120000  # 2 minutes for QR scan timeout (milliseconds)

# Alternative (Recommended for production): Use Twilio
# TWILIO_ACCOUNT_SID=your_account_sid
# TWILIO_AUTH_TOKEN=your_auth_token
# TWILIO_WHATSAPP_NUMBER=+1234567890

# ============ AUTO-CUTOFF SCHEDULER ============
# These are overridable in the UI settings, but serve as defaults
AUTO_CUTOFF_ENABLED=false  # Set to true to enable automatic power cutoffs
CUTOFF_GRACE_DAYS=14       # Grace period after due date before cutoff
CUTOFF_HOUR=10             # Hour of day (IST) to trigger cutoff (0-23)
CUTOFF_NOTIFY_WHATSAPP=true # Send WhatsApp notification on cutoff

# ============ LOGGING ============
DEBUG=rentmanager:*  # Comma-separated list of debug namespaces
LOG_LEVEL=info       # debug, info, warn, error

# ============ SESSION & COOKIES ============
SESSION_SECRET=your-session-secret-key-change-in-production

# ============ CORS ============
# Comma-separated list of allowed origins
CORS_ORIGIN=http://localhost:3000,http://localhost:5000,https://yourdomain.com

# ============ RATE LIMITING ============
RATE_LIMIT_WINDOW_MS=900000  # 15 minutes in milliseconds
RATE_LIMIT_MAX_REQUESTS=100  # Max requests per window per IP

# ============ EMAIL NOTIFICATIONS (Optional) ============
# For email alerts instead of/in addition to WhatsApp
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=your-email@gmail.com
# SMTP_PASSWORD=your-app-password
# SMTP_FROM=noreply@rentmanager.com
# ADMIN_EMAIL=admin@yourdomain.com
